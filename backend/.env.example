# PostgreSQL connection string
DATABASE_URL="postgresql://icemm:STRONG_PASSWORD@localhost:5432/icemm?schema=public"

# Puerto del backend (Nginx hará proxy_pass desde /api/)
PORT=3001

# CORS origins (separados por coma). En prod normalmente es tu dominio o vacío si Nginx sirve todo desde el mismo origen.
# Ejemplo: CORS_ORIGIN=https://icemm.tudominio.com,http://1.2.3.4
CORS_ORIGIN=*

# === BETA MODE ===
# true  → cualquiera con la URL puede usar la app (sin login). Para QA/gerencia.
# false → requiere JWT (login real). Para producción definitiva.
BETA_MODE=true

# Secret para firmar JWT (mínimo 32 chars). Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-long-random-string

NODE_ENV=production
